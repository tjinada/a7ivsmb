# ─── App (single-user web auth) ───────────────────────────
APP_USER=admin
APP_PASS=change-me
JWT_SECRET=change-me-to-a-long-random-string

# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Local state (plain JSON) ─────────────────────────────
DATA_DIR=./data

# ─── Photos share (bind-mounted unraid share) ─────────────
# Host /mnt/user/data/mekala-share is mounted here in the container.
# In local dev, point this at any folder you want to use as the library.
PHOTOS_PATH=/photos

# ─── Embedded FTP receive server (used from Phase 2) ──────
# FTP_ENABLED=true
# FTP_USER=camera
# FTP_PASS=change-me
# FTP_PORT=21
# Passive data-port range. Keep it wide (~40 ports): cameras (esp. Sony)
# often drop data connections without closing them cleanly, so a too-narrow
# pool leaks until "Unable to find valid port" / PASV hangs. See
# docs/TROUBLESHOOTING.md. Must match the published range in docker-compose.
# FTP_PASV_MIN=50000
# FTP_PASV_MAX=50049
# FTP_EXTERNAL_IP=192.168.1.10   # unraid LAN IP advertised for PASV
# FTPS_ENABLED=false             # optional TLS for the camera login

# ─── Client shares (proofing links) ───────────────────────
# Hostname of the public client-share surface (Option B isolation). Put the
# client gallery on its own subdomain with NO Cloudflare Access policy; the
# owner app + API stay protected on the main host. When set, owner endpoints
# and the PWA shell 404 on this host. Leave unset in local dev.
# SHARE_HOST=share.yourdomain.com
# Optional preview tuning (defaults shown):
# SHARE_PREVIEW_MAX_EDGE=1600
# SHARE_PREVIEW_QUALITY=80
# SHARE_WATERMARK_TEXT=Preview
# SHARE_COOKIE_TTL_DAYS=7
